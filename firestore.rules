rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ====================================================
    // 1. HELPER FUNCTIONS
    // ====================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks if the user is an admin by reading their user document
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Only these specific emails can auto-create their account with the 'admin' role
    function isAutoAdminEmail() {
      return request.auth.token.email != null && 
        request.auth.token.email.lower() in [
          'wpa@esnporto.org', 
          'office.team@esnporto.org', 
          'treasurer@esnporto.org'
        ];
    }

    // ====================================================
    // 2. COLLECTION RULES
    // ====================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      
      // CREATE: Strict auto-admin list applies here
      allow create: if isOwner(userId) && (
        (request.resource.data.role == 'admin' && isAutoAdminEmail()) ||
        (request.resource.data.role == 'member')
      );
      
      // UPDATE: Admins can update users. If they are setting role to 'admin', 
      // the target user's email MUST end in @esnporto.org
      allow update: if 
        (isAdmin() && (request.resource.data.role != 'admin' || request.resource.data.email.lower().matches('.*@esnporto\\.org'))) || 
        (isOwner(userId) && request.resource.data.role == resource.data.role);
      
      allow delete: if isAdmin();
    }

    // --- CATEGORIES ---
    match /categories/{categoryId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // --- ITEMS ---
    match /items/{itemId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      
      // Admins can change anything (name, photo, category).
      // Members can ONLY change fields related to checking items in/out.
      allow update: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'currentHolder', 'currentHolderName', 'currentHolderPhoto', 'updatedAt'])
      );
    }

    // --- TRANSFERS (AUDIT LOG) ---
    match /transfers/{transferId} {
      allow read: if true;
      
      // Authenticated users can create a history record
      allow create: if isAuthenticated();
      
      // IMMUTABLE: No one can edit or delete history once it's written
      allow update, delete: if false;
    }
  }
}